{
  "name": "academia-saas",
  "version": "1.0.0",
  "private": true,
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "dev": "next dev -p 3300",
    "build": "next build",
    "start": "node scripts/graceful-start.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "qa": "npm run lint && npm run typecheck && npm run test && npm run build && npm audit --omit=dev --audit-level=moderate",
    "qa:full": "npm run qa && npm run test:e2e && npm run db:test",
    "demo:credentials": "tsx scripts/demo-credentials.ts",
    "create-superadmin": "tsx scripts/create-superadmin.ts",
    "jobs": "tsx scripts/run-jobs.ts",
    "db:start": "npx supabase start",
    "db:reset": "npx supabase db reset",
    "db:test": "npx supabase test db"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@aws-sdk/s3-request-presigner": "^3.850.0",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.0.12",
    "exceljs": "3.10.0",
    "jspdf": "4.2.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "nodemailer": "9.0.3",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.30.1",
    "eslint-config-next": "16.2.10",
    "jsdom": "^26.1.0",
    "supabase": "^2.30.4",
    "tailwindcss": "4.3.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "4.1.10"
  },
  "overrides": { "next": { "postcss": "8.5.10" }, "exceljs": { "uuid": "11.1.1" } }
}
